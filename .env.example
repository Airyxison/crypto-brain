# Copy this to .env and fill in your values.
# .env is gitignored — never commit the real file.

# W&B experiment tracking (get from wandb.ai/settings)
WANDB_API_KEY=

# AWS credentials (only needed if not using IAM instance profile)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for checkpoint sync
S3_BUCKET=nova-trader-data-249899228939-us-east-1-an

# Tick database path (override default /root/crypto-engine/ticks.db)
# TICKS_DB_PATH=/path/to/ticks.db
